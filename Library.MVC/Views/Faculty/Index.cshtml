

@model IEnumerable<Library.MVC.Models.Course>

<h2>My Assigned Courses</h2>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Course Name</th>
            <th>Start Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>
                    <a asp-action="StudentList" asp-route-courseId="@item.Id" class="btn btn-sm btn-info">View Students</a> |
                    <a asp-controller="AssignmentResults" asp-action="Index" asp-route-courseId="@item.Id" class="btn btn-sm btn-primary">Gradebook</a>
                </td>
            </tr>
        }
    </tbody>
</table>