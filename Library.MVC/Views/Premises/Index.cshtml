@model IEnumerable<Library.MVC.Models.Premises>

@{
    ViewData["Title"] = "Premises Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Registered Premises</h1>
    @if (User.IsInRole("Admin") || User.IsInRole("Inspector"))
    {
        <a asp-action="Create" class="btn btn-primary">Add New Premises</a>
    }
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th> @* Ajout de l'ID *@
                    <th>Name</th>
                    <th>Address</th> @* Ajout de l'Adresse *@
                    <th>Town</th>
                    <th>Risk Rating</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><small class="text-muted">#@item.Id</small></td> @* Affichage ID *@
                        <td><strong>@item.Name</strong></td>
                        <td>@item.Address</td> @* Affichage Adresse *@
                        <td>@item.Town</td>
                        <td>
                            <span class="badge @(item.RiskRating == "High" ? "bg-danger" : (item.RiskRating == "Medium" ? "bg-warning text-dark" : "bg-info"))">
                                @item.RiskRating
                            </span>
                        </td>
                        <td class="text-end">
                            @if (User.IsInRole("Admin"))
                            {
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Are you sure you want to delete this premises?');">
                                    <button type="submit" class="btn btn-sm btn-danger ml-1">Delete</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>