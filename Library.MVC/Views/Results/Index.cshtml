@model IEnumerable<Library.MVC.Models.AssignmentResult>

@{
    ViewData["Title"] = "Mes Résultats";
}

<h1>Liste des Résultats</h1>

<table class="table">
    <thead>
        <tr>
            <th>Devoir</th>
            <th>Score</th>
            <th>Note Max</th>
            <th>Commentaire</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Assignment.Title</td>
                <td><strong>@item.Score</strong></td>
                <td>@item.Assignment.MaxScore</td>
                <td>@item.Feedback</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Modifier</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Détails</a>
                </td>
            </tr>
        }
    </tbody>
</table>