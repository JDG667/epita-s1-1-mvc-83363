@model Library.MVC.Models.AssignmentResult

@{
    ViewData["Title"] = "Add grade";
}

<h1>Nouveau Résultat</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group mb-3">
                <label>Étudiant</label>
                <select asp-for="StudentProfileId" class="form-control" asp-items="ViewBag.StudentProfileId"></select>
            </div>

            <div class="form-group mb-3">
                <label>Devoir / Examen</label>
                <select asp-for="AssignmentId" class="form-control" asp-items="ViewBag.AssignmentId"></select>
            </div>

            <div class="form-group mb-3">
                <label>Score obtenu</label>
                <input asp-for="Score" class="form-control" type="number" />
            </div>

            <div class="form-group mb-3">
                <label>Feedback</label>
                <textarea asp-for="Feedback" class="form-control"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Enregistrer</button>
            <a asp-action="Index" class="btn btn-secondary">Retour</a>
        </form>
    </div>
</div>