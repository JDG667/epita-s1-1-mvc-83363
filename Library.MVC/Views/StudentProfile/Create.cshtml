@model Library.MVC.Models.StudentProfile

<h2>Créer un Profil Étudiant</h2>

<form asp-action="Create">
    <div class="form-group">
        <label asp-for="IdentityUserId" class="control-label">ID Utilisateur Identity</label>
        <input asp-for="IdentityUserId" class="form-control" placeholder="Coller le GUID de AspNetUsers" />
    </div>
    <div class="form-group">
        <label asp-for="Name" class="control-label">Nom Complet</label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="form-group">
        <label asp-for="StudentNumber" class="control-label">Numéro Étudiant</label>
        <input asp-for="StudentNumber" class="form-control" />
    </div>
    <br />
    <button type="submit" class="btn btn-success">Enregistrer</button>
    <a asp-action="Index" class="btn btn-secondary">Retour</a>
</form>