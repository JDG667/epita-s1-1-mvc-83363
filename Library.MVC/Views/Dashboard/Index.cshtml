@model Library.MVC.Models.DashboardViewModel

<h1 class="mb-4">Reporting Dashboard</h1>

<div class="card bg-light mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-4">
                <select name="town" class="form-select" asp-items="@(new SelectList(Model.Towns))">
                    <option value="">-- All Towns --</option>
                </select>
            </div>
            <div class="col-md-4">
                <select name="riskRating" class="form-select" asp-items="@(new SelectList(Model.RiskRatings))">
                    <option value="">-- All Risk Ratings --</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-dark w-100">Filter Results</button>
            </div>
        </form>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body text-center">
                <h5 class="card-title">Inspections (This Month)</h5>
                <p class="display-4">@Model.TotalInspectionsThisMonth</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body text-center">
                <h5 class="card-title">Failed Inspections (This Month)</h5>
                <p class="display-4">@Model.FailedInspectionsThisMonth</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body text-center text-dark">
                <h5 class="card-title">Overdue Follow-ups</h5>
                <p class="display-4">@Model.OverdueOpenFollowUps</p>
            </div>
        </div>
    </div>
</div>