@model IEnumerable<Library.MVC.Models.FollowUp>

@{
    ViewData["Title"] = "Follow-Up Tasks";
}

<div class="mb-4">
    <h1><i class="bi bi-calendar-check"></i> Follow-Up Inspections</h1>
</div>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>ID</th> @* 1. Ajout de l'ID du Follow-up *@
                    <th>Establishment (ID)</th> @* 2. Ajout de l'ID du Premises dans l'en-tête *@
                    <th>Inspection Date</th>
                    <th>Due Date</th>
                    <th>Status</th>
                    <th>Closed Date</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    bool isOverdue = item.Status == "Open" && item.DueDate < DateTime.Now;
                    bool isClosed = item.Status == "Closed";

                    <tr>
                        @* ID du Follow-Up *@
                        <td><small class="text-muted">#@item.Id</small></td>

                        @* Nom de l'établissement + ID du Premises *@
                        <td class="fw-bold">
                            @(item.Inspection?.Premises?.Name ?? "N/A")
                            @if (item.Inspection?.Premises != null)
                            {
                                <span class="badge bg-secondary ms-1" style="font-size: 0.75rem;">ID: @item.Inspection.PremisesId</span>
                            }
                        </td>

                        @* Date de l'inspection initiale *@
                        <td>
                            @if (item.Inspection != null)
                            {
                                @item.Inspection.InspectionDate.ToString("dd/MM/yyyy")
                            }
                            else
                            {
                                <span class="text-muted small">None</span>
                            }
                        </td>

                        @* Due Date *@
                        <td>
                            <span class="@(isOverdue ? "text-danger fw-bold" : "")">
                                @item.DueDate.ToString("dd/MM/yyyy")
                            </span>
                        </td>

                        @* Badge de Statut *@
                        <td>
                            @if (isOverdue)
                            {
                                <span class="badge bg-danger">
                                    <i class="bi bi-exclamation-triangle-fill"></i> Overdue
                                </span>
                            }
                            else if (isClosed)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-check-circle"></i> Closed
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-clock"></i> Open
                                </span>
                            }
                        </td>

                        @* Closed Date *@
                        <td>
                            @if (isClosed)
                            {
                                if (item.ClosedDate.HasValue)
                                {
                                    <span class="text-success fw-bold">
                                        <i class="bi bi-calendar-check"></i> @item.ClosedDate.Value.ToString("dd/MM/yyyy")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-warning small italic">Date missing</span>
                                }
                            }
                            else if (isOverdue)
                            {
                                <span class="text-danger small fw-bold">LATE</span>
                            }
                            else
                            {
                                <span class="text-muted small">Pending...</span>
                            }
                        </td>

                        @* Actions *@
                        <td class="text-center">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>

                                @if (item.Status == "Open")
                                {
                                    <form asp-action="Complete" asp-route-id="@item.Id" method="post" class="d-inline ms-1">
                                        <button type="submit" class="btn btn-sm btn-success">
                                            Close
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info mt-3 text-center">
        <i class="bi bi-info-circle"></i> No follow-up tasks available.
    </div>
}