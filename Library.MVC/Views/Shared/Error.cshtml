@model ErrorViewModel
@{
    ViewData["Title"] = "System Error";
}

<div class="text-center mt-5">
    <h1 class="display-4 text-danger"><i class="bi bi-exclamation-triangle"></i> Oops!</h1>
    <p class="lead">An unexpected error occurred while processing your request.</p>
    <hr />
    <p>The technical team has been notified (Transaction ID: <strong>@Model.RequestId</strong>).</p>
    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Back to Home</a>
</div>