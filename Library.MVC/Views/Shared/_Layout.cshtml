<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Acme Global College</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        :root {
            --primary-color: #4e73df;
            --secondary-color: #858796;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fc;
            color: #2e2e2e;
        }

        .navbar {
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
            padding: 0.8rem 1rem;
        }

        .navbar-brand {
            font-size: 1.4rem;
            letter-spacing: -0.5px;
            color: var(--primary-color) !important;
        }

        /* Animation au survol des liens du menu */
        .nav-link {
            transition: all 0.2s ease-in-out;
            font-weight: 500;
        }

            .nav-link:hover {
                color: var(--primary-color) !important;
                transform: translateY(-2px);
            }

        /* Bouton Admin stylisé */
        .btn-admin-panel {
            background-color: rgba(78, 115, 223, 0.1);
            border-radius: 8px;
            padding: 0.5rem 1rem;
        }

        /* Conteneur principal avec transition douce */
        .page-content {
            animation: fadeIn 0.5s ease;
        }

        footer {
            background: white;
            padding: 2rem 0;
            margin-top: 3rem;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom mb-4 sticky-top">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold animate__animated animate__pulse" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-mortarboard-fill"></i> VGC College
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i> Home
                            </a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {@if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item dropdown ms-lg-2">
                                    <a class="nav-link dropdown-toggle text-primary fw-bold btn-admin-panel" href="#" id="adminMenu" data-bs-toggle="dropdown">
                                        <i class="bi bi-shield-lock-fill"></i> Admin Panel
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 animate__animated animate__fadeIn">
                                        @* 1. VUE D'ENSEMBLE *@
                                        <li>
                                            <a class="dropdown-item py-2" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                                                <i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>

                                        @* 2. STRUCTURE *@
                                        <li>
                                            <a class="dropdown-item py-2" asp-area="Admin" asp-controller="Branches" asp-action="Index">
                                                <i class="bi bi-building me-2 text-secondary"></i>Manage Branches
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item py-2" asp-area="Admin" asp-controller="Courses" asp-action="Index">
                                                <i class="bi bi-book me-2 text-secondary"></i>Manage Courses
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item py-2" asp-area="Admin" asp-controller="Timetables" asp-action="Index">
                                                <i class="bi bi-calendar3 me-2 text-info"></i>Timetables
                                            </a>
                                        </li>

                                        <li><hr class="dropdown-divider"></li>

                                        @* 3. UTILISATEURS ET INSCRIPTIONS *@
                                        <li>
                                            <a class="dropdown-item py-2" asp-area="Admin" asp-controller="Students" asp-action="Index">
                                                <i class="bi bi-people me-2 text-warning"></i>Student Management
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item py-2" asp-area="Admin" asp-controller="Enrolments" asp-action="Index">
                                                <i class="bi bi-person-plus me-2 text-success"></i>Student Enrolments
                                            </a>
                                        </li>
                                    </ul>
                                </li>
                            }

                            @if (User.IsInRole("Faculty"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Faculty" asp-controller="Dashboard" asp-action="Index">
                                        <i class="bi bi-journal-text"></i> Gradebook
                                    </a>
                                </li>
                            }

                            @if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-area="Student" asp-controller="Portal" asp-action="Index">
                                        <i class="bi bi-person-badge"></i> My Portal
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link text-dark"
                                       asp-area="Student"
                                       asp-controller="Student"
                                       asp-action="MyGrades">
                                        <i class="bi bi-journal-check"></i> My Gradebook
                                    </a>
                                </li>
                            }
                        }
                    </ul>

                    <div class="d-flex align-items-center">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container page-content">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-center text-muted">
        <div class="container">
            <p class="mb-0">&copy; 2026 - <strong>Acme Global College</strong> | <i class="bi bi-shield-check"></i> Secure Portal</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @* Très important pour activer DataTables ou SweetAlert dans tes vues *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>