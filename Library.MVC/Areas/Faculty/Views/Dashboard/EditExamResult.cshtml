@model Library.MVC.Models.ExamResult

<h2>Modify Exam Grade</h2>

<form asp-action="EditExamResult" method="post">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ExamId" />
    <input type="hidden" asp-for="StudentProfileId" />

    <div class="form-group mb-3">
        <label>Score (%)</label>
        <input asp-for="Score" class="form-control" type="number" min="0" max="100" />
    </div>

    <div class="form-group mb-3">
        <label>Grade (Letter)</label>
        <select asp-for="Grade" class="form-control">
            <option value="A">A</option>
            <option value="B">B</option>
            <option value="C">C</option>
            <option value="D">D</option>
            <option value="F">F</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Register</button>
    <a asp-action="Gradebook" asp-route-id="@Model.Exam.CourseId" class="btn btn-secondary">Go Back</a>
</form>