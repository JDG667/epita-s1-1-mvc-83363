@model IEnumerable<Library.MVC.Models.Course>

<div class="container mt-4">
    <h2 class="fw-bold mb-4">Matières Enseignées</h2>

    <div class="accordion" id="courseAccordion">
        @foreach (var course in Model)
        {
            <div class="accordion-item mb-3 border shadow-sm">
                <h2 class="accordion-header d-flex align-items-center bg-light">
                    <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#course-@course.Id" style="width: auto; flex-grow: 1;">
                        <div class="d-flex justify-content-between w-100 px-3">
                            <span><strong>@course.Name</strong></span>
                            <span class="badge bg-info text-dark me-3">@course.Branch?.Name</span>
                        </div>
                    </button>

                    @* --- LE BOUTON AJOUTÉ ICI --- *@
                    <div class="pe-3">
                        <a asp-action="Gradebook" asp-route-id="@course.Id" class="btn btn-sm btn-dark">
                            <i class="bi bi-table"></i> Manage the Grades
                        </a>
                    </div>
                </h2>

                <div id="course-@course.Id" class="accordion-collapse collapse" data-bs-parent="#courseAccordion">
                    <div class="accordion-body p-0">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Student</th>
                                    <th>Assignments Average</th>
                                    <th>Contact</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var enrol in course.Enrolments)
                                {
                                    <tr>
                                        <td>@enrol.Student.Name</td>
                                        <td>
                                            @{
                                                var avg = enrol.Student.AssignmentResults
                                                .Where(r => r.Assignment?.CourseId == course.Id)
                                                .Select(r => r.Score).DefaultIfEmpty(0).Average();
                                            }
                                            <span class="badge @(avg >= 40 ? "bg-success" : "bg-danger")">@avg.ToString("0")%</span>
                                        </td>
                                        <td>
                                            @if (ViewBag.IsTutor == true)
                                            {
                                                <small>@enrol.Student.Email</small>
                                            }
                                            else
                                            {
                                                <i class="bi bi-lock-fill text-muted"></i>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>