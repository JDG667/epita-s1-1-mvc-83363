@model Library.MVC.Models.StudentProfile

@{
    ViewData["Title"] = "My Student Profile";
}

<div class="container mt-5 animate__animated animate__fadeIn">
    <div class="row">
        <div class="col-md-4">
            <div class="card shadow-sm border-0 text-center p-4">
                <div class="mb-3">
                    <i class="bi bi-person-circle text-warning" style="font-size: 5rem;"></i>
                </div>
                <h3 class="fw-bold">@Model.Name</h3>
                <span class="badge bg-secondary-subtle text-secondary border mb-3">Student #@Model.StudentNumber</span>
                <hr />
                <div class="text-start ms-3">
                    <p class="mb-1 text-muted small"><i class="bi bi-envelope me-2"></i>Email</p>
                    <p class="fw-semibold">@Model.Email</p>

                    <p class="mb-1 text-muted small"><i class="bi bi-telephone me-2"></i>Phone</p>
                    <p class="fw-semibold">@Model.Phone</p>

                    <p class="mb-1 text-muted small"><i class="bi bi-geo-alt me-2"></i>Address</p>
                    <p class="fw-semibold">@Model.Address</p>

                    <p class="mb-1 text-muted small"><i class="bi bi-calendar-event me-2"></i>Date of Birth</p>
                    <p class="fw-semibold">@Model.DateOfBirth.ToLongDateString()</p>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card shadow-sm border-0 p-4">
                <h4 class="fw-bold mb-4"><i class="bi bi-journal-bookmark-fill text-warning me-2"></i>My Enrolled Courses</h4>

                @if (Model.Enrolments != null && Model.Enrolments.Any())
                {
                    <div class="list-group list-group-flush">
                        @foreach (var enrolment in Model.Enrolments)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center py-3 border-0 border-bottom">
                                <div>
                                    <h6 class="mb-0 fw-bold">@enrolment.Course?.Name</h6>
                                    <small class="text-muted">Enrolled on: @enrolment.EnrolDate.ToShortDateString()</small>
                                </div>
                                <span class="badge bg-success-subtle text-success border px-3 rounded-pill">
                                    @enrolment.Status
                                </span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-inbox text-muted display-1"></i>
                        <p class="mt-3 text-muted">You are not enrolled in any courses yet.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>