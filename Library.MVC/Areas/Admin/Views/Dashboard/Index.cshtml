<div class="row g-4">
    <div class="col-md-4 animate__animated animate__fadeInUp" style="animation-delay: 0.1s;">
        <div class="card admin-card text-white bg-gradient-blue h-100 shadow border-0">
            <div class="card-body p-4">
                <div class="icon-circle"><i class="bi bi-building fs-4"></i></div>
                <h4 class="fw-bold">Branches</h4>
                <p class="opacity-75">Manage campus locations.</p>
                <a asp-controller="Branches" asp-action="Index" class="btn btn-light rounded-pill btn-sm fw-bold">Manage</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 animate__animated animate__fadeInUp" style="animation-delay: 0.2s;">
        <div class="card admin-card text-white bg-gradient-green h-100 shadow border-0">
            <div class="card-body p-4">
                <div class="icon-circle"><i class="bi bi-book fs-4"></i></div>
                <h4 class="fw-bold">Courses</h4>
                <p class="opacity-75">Curriculum and programs.</p>
                <a asp-controller="Courses" asp-action="Index" class="btn btn-light rounded-pill btn-sm fw-bold">Manage</a>
            </div>
        </div>
    </div>

    <div class="col-md-4 animate__animated animate__fadeInUp" style="animation-delay: 0.3s;">
        <div class="card admin-card text-white bg-gradient-orange h-100 shadow border-0">
            <div class="card-body p-4 text-dark">
                <div class="icon-circle" style="background: rgba(0,0,0,0.1);"><i class="bi bi-people-fill fs-4"></i></div>
                <h4 class="fw-bold">Users</h4>
                <p class="opacity-75">Staff and Student accounts.</p>
                <a asp-controller="Users" asp-action="Index" class="btn btn-dark rounded-pill btn-sm fw-bold">Manage</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 animate__animated animate__fadeInUp" style="animation-delay: 0.4s;">
        <div class="card admin-card border-0 shadow-sm h-100" style="background: #eef2f7;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-success text-white p-3 rounded-3 me-3"><i class="bi bi-person-check fs-4"></i></div>
                    <div>
                        <h5 class="fw-bold mb-0">Enrolments</h5>
                        <small class="text-muted">Register students to courses</small>
                    </div>
                </div>
                <a asp-controller="Enrolments" asp-action="Index" class="btn btn-outline-success w-100 rounded-pill">View Registrations</a>
            </div>
        </div>
    </div>

    <div class="col-md-6 animate__animated animate__fadeInUp" style="animation-delay: 0.5s;">
        <div class="card admin-card border-0 shadow-sm h-100" style="background: #fff4f4;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-danger text-white p-3 rounded-3 me-3"><i class="bi bi-calendar-event fs-4"></i></div>
                    <div>
                        <h5 class="fw-bold mb-0">Timetables</h5>
                        <small class="text-muted">Class schedules and rooms</small>
                    </div>
                </div>
                <a asp-controller="Timetables" asp-action="Index" class="btn btn-outline-danger w-100 rounded-pill">Manage Schedule</a>
            </div>
        </div>
    </div>
</div>