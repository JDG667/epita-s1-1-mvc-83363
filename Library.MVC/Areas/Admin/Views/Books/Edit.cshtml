@model Library.MVC.Models.Book

<h2>Edit Book</h2>

<form asp-area="Admin" asp-controller="Books" asp-action="Edit" method="post">

    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label>Title</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Author</label>
        <input asp-for="Author" class="form-control" />
    </div>

    <div class="mb-3">
        <label>ISBN</label>
        <input asp-for="Isbn" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Category</label>
        <input asp-for="Category" class="form-control" />
    </div>

    <div class="form-check">
        <input asp-for="IsAvailable" class="form-check-input" />
        <label class="form-check-label">Available</label>
    </div>

    <br />

    <button type="submit" class="btn btn-primary">Save</button>

    <a asp-area="Admin" asp-controller="Books" asp-action="Index" class="btn btn-secondary">
        Back
    </a>

</form>