@model Library.MVC.Models.Book

<h2>Delete Book</h2>

<p>Are you sure you want to delete this book?</p>

<div>
    <strong>@Model.Title</strong> - @Model.Author
</div>

<br />

<form asp-area="Admin" asp-controller="Books" asp-action="Delete" method="post">

    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-area="Admin" asp-controller="Books" asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>

</form>