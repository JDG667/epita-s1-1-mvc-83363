@model IEnumerable<Library.MVC.Models.CourseEnrolment>

<div class="animate__animated animate__fadeIn">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark"><i class="bi bi-person-plus-fill text-success"></i> Student Enrolments</h2>
            <p class="text-muted">Manage active registrations and course entry dates.</p>
        </div>
        <a asp-action="Create" class="btn btn-success shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-lg me-2"></i>New Enrolment
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-dark text-white">
                        <tr>
                            <th class="ps-4">Student</th>
                            <th>Course</th>
                            <th>Enrolment Date</th>
                            <th>Status</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-primary">@item.Student?.Name</div>
                                    <small class="text-muted">ID: @item.StudentProfileId</small>
                                </td>
                                <td>
                                    <div class="fw-semibold">@item.Course?.Name</div>
                                </td>
                                <td>
                                    <i class="bi bi-calendar-check me-1 text-secondary"></i>
                                    @item.EnrolDate.ToShortDateString()
                                </td>
                                <td>
                                    @{
                                        var statusClass = item.Status == "Confirmed" ? "bg-success" : "bg-warning text-dark";
                                    }
                                    <span class="badge @statusClass">@item.Status</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary border-0"><i class="bi bi-pencil"></i></a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Cancel this enrolment?')" style="display:inline">
                                            <button type="submit" class="btn btn-sm btn-outline-danger border-0"><i class="bi bi-trash"></i></button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>