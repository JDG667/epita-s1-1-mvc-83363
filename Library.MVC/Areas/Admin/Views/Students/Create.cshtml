@model Library.MVC.Models.StudentProfile
<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark"><h4>Add New Student</h4></div>
        <div class="card-body">
            <form asp-action="Create">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Full Name</label>
                        <input asp-for="Name" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Student Number</label>
                        <input asp-for="StudentNumber" type="number" class="form-control" required />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <input asp-for="Email" type="email" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Phone</label>
                        <input asp-for="Phone" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Date of Birth</label>
                    <input asp-for="DateOfBirth" type="date" class="form-control" required />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">Address</label>
                    <textarea asp-for="Address" class="form-control" rows="2"></textarea>
                </div>
                @* Important : Pour les tests, on peut laisser IdentityUserId vide ou le lier manuellement *@
                <input type="hidden" asp-for="IdentityUserId" value="temporary_id_for_test" />

                <div class="mt-3">
                    <button type="submit" class="btn btn-warning px-4 fw-bold">Save Student</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>