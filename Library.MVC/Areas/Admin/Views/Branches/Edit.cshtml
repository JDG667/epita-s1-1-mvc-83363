@model Library.MVC.Models.Branch

@{
    ViewData["Title"] = "Edit Branch";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Edit Branch</h4>
        </div>
        <div class="card-body p-4">
            <form asp-action="Edit" method="post">
                @* 1. Protection Anti-Forgery (Optionnel mais recommandé) *@
                @Html.AntiForgeryToken()

                @* 2. Résumé des erreurs de validation *@
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                @* 3. ID caché indispensable pour l'Update *@
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Branch Name</label>
                    <input asp-for="Name" class="form-control" placeholder="Enter branch name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label fw-bold">Full Address</label>
                    <input asp-for="Address" class="form-control" placeholder="123 Street, City, Country" />
                    <span asp-validation-for="Address" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between border-top pt-3 mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-arrow-left"></i> Back to List
                    </a>
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        @* 4. Validation côté client (évite de recharger la page pour rien) *@
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}